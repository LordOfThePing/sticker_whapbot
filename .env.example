# Copy to .env and adjust. Values shown are defaults or placeholders.

# --- runtime ---
NODE_ENV=production

# --- bot identity ---
BOT_NAME=Stegripe WhatsApp Bot
STICKER_PACK_NAME=Stegripe Sticker Pack
PREFIX=/

# Comma-separated WhatsApp numbers (digits, country code, no spaces) for dev-only features.
# Also used as fallback for PAIR_PHONE if PAIR_PHONE is unset (first entry, 10–15 digits).
DEVS=5490000000000

# Optional: override phone used for "link with phone number" pairing (digits only; no +).
# If unset, first DEVS entry is used when it looks like a full international number (10–15 digits).
# Required for the printed link code; each new QR triggers a fresh code request (debounced).
# PAIR_PHONE=5490000000000

# Optional passthrough (reserved / future use)
# WS=

# --- safety & throttling (defaults match dist/config.js) ---
MAX_CONCURRENT_REQUESTS=5
MAX_WAITLIST_SIZE=40
MIN_SAFE_SEND_DELAY_MS=500
MAX_SAFE_SEND_DELAY_MS=1600
USER_COOLDOWN_MS=1500
CHAT_COOLDOWN_MS=1200
DEDUPE_WINDOW_MS=5000
BUSY_MESSAGE=Busy, please wait.
TOO_BUSY_MESSAGE=Too busy to handle right now, please try again later.
ALLOW_EXISTING_CHATS_ONLY=true

# Path to known-contacts JSON (existing-chats-only policy). Docker: e.g. /data/known_contacts.json
KNOWN_CONTACTS_PATH=known_contacts.json

# NDJSON log file. Default when unset: data/bot.log. Set empty to disable file logging: LOG_FILE_PATH=
LOG_FILE_PATH=
LOG_MAX_STRING_CHARS=120

# Baileys init IQs (props/blocklist/privacy). false reduces bad-request noise on some accounts.
FIRE_INIT_QUERIES=false

# --- meme captions for /sticker (optional) ---
# If OPENAI_API_KEY is set, /sticker <phrase> on images uses GPT for the caption.
# Videos use your phrase as the title directly (no GPT). Images without a key use your phrase as-is.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# MEME_CAPTION_ENABLED=true
# MEME_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
